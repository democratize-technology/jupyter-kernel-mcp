# Jupyter Kernel MCP Configuration

# ==== COMMON SETUP (Local Jupyter) ====
# For most users, uncomment and set your token:

JUPYTER_HOST=localhost
JUPYTER_PORT=8888
# JUPYTER_TOKEN=<paste-your-token-here>

# To get your token, run: jupyter server list
# You'll see: http://localhost:8888/?token=abc123...
# Copy the token value (abc123...) above

# ==== ADVANCED OPTIONS ====

# HTTPS/WSS Setup (if your Jupyter uses SSL)
# JUPYTER_PROTOCOL=https
# JUPYTER_WS_PROTOCOL=wss

# Remote Jupyter Server
# JUPYTER_HOST=jupyter.example.com
# JUPYTER_PORT=8888

# ==== DOCKER SETUP (Advanced) ====
# Only if Jupyter runs in Docker AND you want automatic token retrieval

# Enable Docker token retrieval (default: false)
# USE_DOCKER_TOKEN=true

# Docker container name (default: jupyter)
# DOCKER_CONTAINER_NAME=my-jupyter-container

# Docker context (leave empty for default)
# DOCKER_CONTEXT=my-remote-context